# Frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
MAX_QUERY_LENGTH=5000
QUERY_HISTORY_LIMIT_DEFAULT=50
QUERY_HISTORY_LIMIT_MAX=200
DASHBOARD_DAYS_DEFAULT=7
DASHBOARD_DAYS_MAX=30
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,txt
RAG_PROMPT_VERSION=rag_prompt_v1
EMBEDDING_MODEL_VERSION=sentence-transformers/all-MiniLM-L6-v2
INDEX_VERSION=local-dev
MODEL_VERSION=groq-sarvam-v1
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_RETRIES=2
SARVAM_TIMEOUT_SECONDS=15
SARVAM_MAX_RETRIES=1
CORS_ALLOWED_ORIGINS=http://localhost:3000
ALLOW_INMEMORY_REPOSITORY=false
# Agent models
RESEARCHER_MODEL=llama-3.1-8b-instant
CRITIC_MODEL=llama-3.1-8b-instant
SYNTHESIZER_MODEL=llama-3.1-70b-versatile
JUDGE_MODEL=sarvam-judge-model

# LLM provider models
SARVAM_CHAT_MODEL=sarvam-m

# Embedding models (these were already env-read, just documenting)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_BGE=BAAI/bge-base-en-v1.5
