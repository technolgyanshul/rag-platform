# Frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_BASE_URL=http://backend:8000
CLOUDFLARED_TOKEN=

# Backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
MAX_QUERY_LENGTH=5000
QUERY_HISTORY_LIMIT_DEFAULT=50
QUERY_HISTORY_LIMIT_MAX=200
DASHBOARD_DAYS_DEFAULT=7
DASHBOARD_DAYS_MAX=30
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,txt
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_documents
EMBEDANYTHING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDANYTHING_CHUNK_STRATEGY=semantic
EMBEDANYTHING_BATCH_SIZE=32
RAG_PROMPT_VERSION=rag_prompt_v1
EMBEDDING_MODEL_VERSION=sentence-transformers/all-MiniLM-L6-v2
INDEX_VERSION=embedanything-qdrant-semantic-v1
MODEL_VERSION=groq-sarvam-v1
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=https://your-clickhouse-cloud-host:8443
CLICKHOUSE_DATABASE=rag_logs
CLICKHOUSE_USERNAME=cloud_user
CLICKHOUSE_PASSWORD=cloud_password
CLICKHOUSE_STRICT=false
CLICKHOUSE_LOG_RAW_PAYLOADS=false
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=5
CLICKHOUSE_READ_TIMEOUT_SECONDS=15
CLICKHOUSE_INIT_MAX_RETRIES=2
CLICKHOUSE_INIT_RETRY_BACKOFF_SECONDS=1
RAG_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_RETRIES=2
SARVAM_TIMEOUT_SECONDS=15
SARVAM_MAX_RETRIES=1
CORS_ALLOWED_ORIGINS=https://rag.anshul-garg.com,http://localhost:3000
ALLOW_INMEMORY_REPOSITORY=false

# LLM provider models
SARVAM_CHAT_MODEL=sarvam-m
GROQ_AGENT_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
SARVAM_AGENT_MODELS=sarvam-m
RESEARCHER_SYSTEM_PROMPT_DEFAULT=Research the query using provided context and cite evidence.
CRITIC_SYSTEM_PROMPT_DEFAULT=Critique weak claims and flag unsupported statements.
SYNTHESIZER_SYSTEM_PROMPT_DEFAULT=Synthesize findings into a concise, accurate final answer.
RESEARCHER_RESPONSE_STYLE_DEFAULT=evidence-first
CRITIC_RESPONSE_STYLE_DEFAULT=skeptical
SYNTHESIZER_RESPONSE_STYLE_DEFAULT=balanced

# Embedding models (these were already env-read, just documenting)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_BGE=BAAI/bge-base-en-v1.5
